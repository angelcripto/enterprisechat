# Normalización de finales de línea.
#
# .editorconfig exige `end_of_line = crlf` para C# y `dotnet format --verify-no-changes`
# es un paso bloqueante de CI. Sin este fichero, git no normaliza nada: los .cs se fueron
# commiteando con una mezcla de LF y CRLF y el check de formato falla en 72 ficheros.
# Forzamos CRLF en el árbol de trabajo en cualquier plataforma para que el resultado del
# check no dependa del sistema operativo del runner.

* text=auto

*.cs text eol=crlf
*.csproj text eol=crlf
*.sln text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf
*.editorconfig text eol=crlf

# Scripts que ejecuta Windows.
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.iss text eol=crlf

# Scripts y units que ejecuta Linux: CRLF los rompe.
*.sh text eol=lf
*.service text eol=lf

# Binarios: que git no los toque.
*.png binary
*.jpg binary
*.ico binary
*.pfx binary
*.snk binary
*.dll binary
*.exe binary
