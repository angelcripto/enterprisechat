<ui:FluentWindow x:Class="EnterpriseChat.Client.Views.WelcomeWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Bienvenido a EnterpriseChat"
                 Width="440" Height="380"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Bienvenido" />

        <StackPanel Grid.Row="1" Margin="32,8,32,24" VerticalAlignment="Center">
            <TextBlock Text="🎉 Bienvenido a EnterpriseChat Free"
                       FontSize="20" FontWeight="Bold" Margin="0,0,0,12" />
            <TextBlock TextWrapping="Wrap" Opacity="0.85" Margin="0,0,0,18">
                Estás usando la edición gratuita.
                Incluye mensajería 1:1, grupos, búsqueda y archivos
                con un límite de <Bold>10 usuarios concurrentes</Bold>.
            </TextBlock>

            <TextBlock TextWrapping="Wrap" Opacity="0.85" Margin="0,0,0,18">
                ¿Necesitas más usuarios o quieres quitar el banner?
                La edición Pro lo desbloquea introduciendo un serial
                en la pestaña Administración → Licencia.
            </TextBlock>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Comprar Pro"
                           Appearance="Primary"
                           Padding="14,6"
                           Margin="0,0,8,0"
                           Click="BuyPro_OnClick" />
                <ui:Button Content="Tengo serial"
                           Appearance="Secondary"
                           Padding="14,6"
                           Margin="0,0,8,0"
                           Click="HaveSerial_OnClick" />
                <ui:Button Content="Más tarde"
                           Appearance="Secondary"
                           Padding="14,6"
                           Click="Later_OnClick" />
            </StackPanel>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
