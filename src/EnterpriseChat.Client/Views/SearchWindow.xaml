<ui:FluentWindow x:Class="EnterpriseChat.Client.Views.SearchWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:EnterpriseChat.Client.ViewModels"
                 xmlns:proto="clr-namespace:EnterpriseChat.Protocol.Search;assembly=EnterpriseChat.Protocol"
                 mc:Ignorable="d"
                 Title="Buscar en el historial"
                 Width="640" Height="540"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 d:DataContext="{d:DesignInstance Type=vm:SearchViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Buscar" />

        <Grid Grid.Row="1" Margin="16,4,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0"
                        Text="{Binding Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Texto a buscar…">
                <ui:TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                </ui:TextBox.InputBindings>
            </ui:TextBox>
            <ui:Button Grid.Column="1" Margin="8,0,0,0" Content="Buscar"
                       Appearance="Primary" Command="{Binding SearchCommand}" />
        </Grid>

        <ListBox Grid.Row="2" Margin="16,0,16,4"
                 ItemsSource="{Binding Hits}"
                 BorderThickness="0"
                 Background="Transparent"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type proto:SearchHit}">
                    <Border Margin="0,3" Padding="10,8" CornerRadius="6"
                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <StackPanel>
                            <TextBlock FontSize="11" Opacity="0.7">
                                <Run Text="{Binding FromUsername, Mode=OneWay}" />
                                <Run Text=" · " />
                                <Run Text="{Binding SentAt, Mode=OneWay, StringFormat='dd/MM/yyyy HH:mm'}" />
                            </TextBlock>
                            <TextBlock Text="{Binding Body}" TextWrapping="Wrap" Margin="0,4,0,0" />
                            <TextBlock Margin="0,4,0,0" FontSize="10" Opacity="0.6">
                                <Run Text="{Binding RoomName, Mode=OneWay, FallbackValue=DM, TargetNullValue=DM}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="3" Padding="14,6"
                Background="{DynamicResource ControlFillColorDefaultBrush}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusMessage}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding StatusMessage}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding StatusMessage}" />
        </Border>
    </Grid>
</ui:FluentWindow>
