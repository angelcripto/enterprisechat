<ui:FluentWindow x:Class="EnterpriseChat.Client.Views.AdminWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:EnterpriseChat.Client.ViewModels"
                 mc:Ignorable="d"
                 Title="EnterpriseChat — Administración"
                 Width="980" Height="640"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 d:DataContext="{d:DesignInstance Type=vm:AdminViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="EnterpriseChat — Administración" />

        <TabControl Grid.Row="1" Margin="12,0,12,8">
            <TabItem Header="Usuarios">
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <!-- Users grid -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="8" Padding="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DataGrid Grid.Row="0"
                                      ItemsSource="{Binding Users}"
                                      SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      RowBackground="Transparent"
                                      AlternatingRowBackground="#15FFFFFF">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Usuario" Binding="{Binding Username}" Width="120" />
                                    <DataGridTextColumn Header="Nombre" Binding="{Binding FullName}" Width="*" />
                                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="160" />
                                    <DataGridTextColumn Header="Depto" Binding="{Binding DepartmentName}" Width="100" />
                                    <DataGridTextColumn Header="Rol" Binding="{Binding Role}" Width="70" />
                                    <DataGridTemplateColumn Header="Activo" Width="60">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="✓" />
                                                            <Setter Property="Foreground" Value="#22C55E" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                    <Setter Property="Text" Value="✗" />
                                                                    <Setter Property="Foreground" Value="#FF6B6B" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Último login" Binding="{Binding LastLoginDisplay}" Width="130" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="6,8,6,4">
                                <ui:Button Content="Reset contraseña"
                                           Command="{Binding ResetPasswordCommand}"
                                           CommandParameter="{Binding SelectedUser}"
                                           Appearance="Secondary"
                                           Margin="0,0,8,0" />
                                <ui:Button Content="Activar/Desactivar"
                                           Command="{Binding ToggleActiveCommand}"
                                           CommandParameter="{Binding SelectedUser}"
                                           Appearance="Secondary"
                                           Margin="0,0,8,0" />
                                <ui:Button Content="Refrescar"
                                           Command="{Binding RefreshCommand}"
                                           Appearance="Secondary" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Create-user panel -->
                    <Border Grid.Column="1" Margin="12,0,0,0"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="8" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Nuevo usuario" FontSize="16" FontWeight="Bold"
                                       Margin="0,0,0,12" />

                            <TextBlock Text="Usuario" Margin="0,0,0,4" />
                            <ui:TextBox Text="{Binding NewUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="ana"
                                        Margin="0,0,0,10" />

                            <TextBlock Text="Nombre completo" Margin="0,0,0,4" />
                            <ui:TextBox Text="{Binding NewFullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="Ana García"
                                        Margin="0,0,0,10" />

                            <TextBlock Text="Email" Margin="0,0,0,4" />
                            <ui:TextBox Text="{Binding NewEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="ana@empresa.local"
                                        Margin="0,0,0,10" />

                            <TextBlock Text="Contraseña" Margin="0,0,0,4" />
                            <ui:TextBox Text="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Margin="0,0,0,10" />

                            <TextBlock Text="Departamento" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding Departments}"
                                      SelectedItem="{Binding NewDepartment, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      Margin="0,0,0,10" />

                            <TextBlock Text="Rol" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding AvailableRoles}"
                                      SelectedItem="{Binding NewRole, Mode=TwoWay}"
                                      Margin="0,0,0,14" />

                            <ui:Button Content="Crear usuario"
                                       Command="{Binding CreateUserCommand}"
                                       Appearance="Primary"
                                       HorizontalAlignment="Stretch"
                                       Height="34" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Licencia" DataContext="{Binding License}">
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="380" />
                    </Grid.ColumnDefinitions>

                    <!-- Estado actual -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="8" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Estado de la licencia" FontSize="16" FontWeight="Bold" Margin="0,0,0,16" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Edición:" Opacity="0.7" Margin="0,0,16,8" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding EditionLabel}" FontWeight="Bold" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Cap. usuarios:" Opacity="0.7" Margin="0,0,16,8" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CapacityLabel}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Licenciado a:" Opacity="0.7" Margin="0,0,16,8" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LicensedToLabel}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Expira:" Opacity="0.7" Margin="0,0,16,8" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ExpiresLabel}" />
                            </Grid>

                            <ui:Button Content="Quitar licencia"
                                       Appearance="Caution"
                                       HorizontalAlignment="Left"
                                       Margin="0,20,0,0"
                                       Command="{Binding ClearCommand}">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPro}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                            </ui:Button>
                        </StackPanel>
                    </Border>

                    <!-- Activar -->
                    <Border Grid.Column="1" Margin="12,0,0,0"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="8" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Activar nueva licencia" FontSize="16" FontWeight="Bold"
                                       Margin="0,0,0,10" />
                            <TextBlock Text="Pega el código de activación recibido por email."
                                       Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,8" />

                            <ui:TextBox Text="{Binding SerialInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="ECP-XXXX-XXXX-XXXX-XXXX"
                                        FontFamily="Consolas"
                                        FontSize="14"
                                        Margin="0,0,0,12" />

                            <ui:Button Content="Activar"
                                       Command="{Binding ApplyCommand}"
                                       Appearance="Primary"
                                       HorizontalAlignment="Stretch"
                                       Height="34" />

                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       Margin="0,12,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Departamentos">
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="8" Padding="6">
                        <ListBox ItemsSource="{Binding Departments}"
                                 DisplayMemberPath="Name"
                                 BorderThickness="0"
                                 Background="Transparent" />
                    </Border>

                    <Border Grid.Column="1" Margin="12,0,0,0"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="8" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Nuevo departamento" FontSize="16" FontWeight="Bold"
                                       Margin="0,0,0,12" />
                            <TextBlock Text="Nombre" Margin="0,0,0,4" />
                            <ui:TextBox Text="{Binding NewDepartmentName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="Soporte, Comercial, …"
                                        Margin="0,0,0,14" />
                            <ui:Button Content="Crear departamento"
                                       Command="{Binding CreateDepartmentCommand}"
                                       Appearance="Primary"
                                       HorizontalAlignment="Stretch"
                                       Height="34" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Padding="14,6"
                Background="{DynamicResource ControlFillColorDefaultBrush}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusMessage}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding StatusMessage}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding StatusMessage}" />
        </Border>
    </Grid>
</ui:FluentWindow>
