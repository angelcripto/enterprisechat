<ui:FluentWindow x:Class="EnterpriseChat.Client.Views.ConnectionSettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:EnterpriseChat.Client.ViewModels"
                 mc:Ignorable="d"
                 Title="Configuración de conexión"
                 Width="440" Height="280"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 d:DataContext="{d:DesignInstance Type=vm:ConnectionSettingsViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Configuración de conexión" />

        <StackPanel Grid.Row="1" Margin="24,8,24,16" VerticalAlignment="Center">
            <TextBlock Text="URL del servidor" Margin="0,0,0,4" />
            <ui:TextBox Text="{Binding ServerUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="http://servidor:5080"
                        Margin="0,0,0,4" />
            <TextBlock Text="Ejemplo: http://192.168.1.50:5080 o https://chat.empresa.local"
                       Opacity="0.6" FontSize="11" Margin="0,0,0,12" />

            <TextBlock Text="{Binding ValidationError}" Foreground="#FF6B6B" TextWrapping="Wrap"
                       Margin="0,0,0,12" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Cancelar" Command="{Binding CancelCommand}"
                           Appearance="Secondary" Margin="0,0,8,0" />
                <ui:Button Content="Guardar" Command="{Binding SaveCommand}"
                           Appearance="Primary" />
            </StackPanel>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
