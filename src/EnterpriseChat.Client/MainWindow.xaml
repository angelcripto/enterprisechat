<ui:FluentWindow x:Class="EnterpriseChat.Client.MainWindow"
                 x:Name="MainWindowRoot"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:tray="clr-namespace:Wpf.Ui.Tray.Controls;assembly=Wpf.Ui.Tray"
                 xmlns:vm="clr-namespace:EnterpriseChat.Client.ViewModels"
                 mc:Ignorable="d"
                 Title="{Binding TrayLabel}"
                 Icon="pack://application:,,,/Assets/app.ico"
                 Height="660" Width="980"
                 MinHeight="500" MinWidth="780"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 Closing="MainWindow_OnClosing"
                 d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="EnterpriseChat" />

        <tray:NotifyIcon x:Name="TrayIcon"
                         Icon="pack://application:,,,/Assets/app.ico"
                         TooltipText="{Binding TrayLabel}"
                         LeftClick="TrayShow_OnClick">
            <tray:NotifyIcon.Menu>
                <ContextMenu>
                    <MenuItem x:Name="TrayUserMenuItem" IsEnabled="False" FontWeight="Bold" />
                    <Separator />
                    <MenuItem Header="Mostrar EnterpriseChat" Click="TrayShow_OnClick" />
                    <Separator />
                    <MenuItem Header="Cerrar sesión" Click="TrayLogout_OnClick" />
                    <MenuItem Header="Salir" Click="TrayExit_OnClick" />
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>

        <!-- Top connection bar -->
        <Border Grid.Row="1" Padding="14,8" Margin="12,4,12,8"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Status dot + label -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                    <Ellipse Width="10" Height="10" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#888" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ConnectionState}" Value="Conectado">
                                        <Setter Property="Fill" Value="#22C55E" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ConnectionState}" Value="Reconectando…">
                                        <Setter Property="Fill" Value="#F59E0B" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ConnectionState}" Value="Desconectado">
                                        <Setter Property="Fill" Value="#EF4444" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionState}" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="Servidor" FontSize="9" Opacity="0.6" />
                    <TextBlock Text="{Binding ServerUrl}" FontFamily="Consolas" FontSize="12"
                               TextTrimming="CharacterEllipsis" MaxWidth="360" />
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentUserDisplay}" FontSize="12" Opacity="0.8"
                               VerticalAlignment="Center" Margin="0,0,10,0" />
                    <Border CornerRadius="999" Padding="8,2" Background="#444"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="{Binding EditionLabel}" FontSize="10"
                                   Foreground="White" />
                    </Border>
                    <ui:Button Content="Buscar"
                               Appearance="Secondary"
                               Click="OpenSearch_OnClick"
                               Padding="10,4"
                               Margin="0,0,8,0" />
                    <ui:Button Content="Administración"
                               Appearance="Secondary"
                               Click="OpenAdmin_OnClick"
                               Padding="10,4"
                               Margin="0,0,8,0">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                    <ui:Button Content="Configurar"
                               Appearance="Secondary"
                               Click="ConfigureServer_OnClick"
                               Padding="10,4" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Free edition banner (visible only when no Pro license) -->
        <Border Grid.Row="2" Margin="12,0,12,8" Padding="14,8"
                Background="#3B2710"
                BorderBrush="#A5703A" BorderThickness="1"
                CornerRadius="8">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFreeEdition}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding LicenseBannerText}"
                           VerticalAlignment="Center" Foreground="#F0D9B5" />
                <ui:Button Grid.Column="1" Content="💎 Comprar Pro"
                           Appearance="Primary" Padding="10,4" Margin="6,0,6,0"
                           Click="BuyPro_OnClick" />
                <ui:Button Grid.Column="2" Content="🔑 Activar licencia"
                           Appearance="Secondary" Padding="10,4"
                           Click="ActivateLicense_OnClick">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="12,0,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="6">
                <TabControl Background="Transparent" BorderThickness="0">
                    <TabItem Header="Contactos">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ListBox Grid.Row="0"
                                     ItemsSource="{Binding ContactsView}"
                                     SelectedItem="{Binding SelectedContact, Mode=TwoWay}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     HorizontalContentAlignment="Stretch">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ContactViewModel}">
                                        <Grid Margin="2,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Grid.Column="0" Width="10" Height="10" Margin="2,0,8,0"
                                                     VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#666" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                <Setter Property="Fill" Value="#22C55E" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding DisplayName}" Opacity="0.6" FontSize="11"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Border Grid.Column="2" Background="#EF4444" CornerRadius="999"
                                                    MinWidth="20" Height="20" Padding="6,0"
                                                    VerticalAlignment="Center" Margin="6,0,2,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasUnread}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding UnreadCount}" Foreground="White"
                                                           FontSize="11" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel Grid.Row="1" Margin="6,6,6,2">
                                <CheckBox Content="Solo online"
                                          IsChecked="{Binding ShowOnlineOnly, Mode=TwoWay}"
                                          Margin="0,0,0,6" />
                                <ui:Button Content="Actualizar contactos"
                                           Command="{Binding RefreshContactsCommand}"
                                           HorizontalAlignment="Stretch"
                                           Appearance="Secondary" />
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Grupos">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ListBox Grid.Row="0"
                                     ItemsSource="{Binding Rooms}"
                                     SelectedItem="{Binding SelectedRoom, Mode=TwoWay}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     HorizontalContentAlignment="Stretch">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:RoomViewModel}">
                                        <Grid Margin="2,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="#" FontSize="16" FontWeight="Bold"
                                                       Opacity="0.6" Margin="2,0,8,0" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                    <TextBlock Text=" 🔒" FontSize="10" Margin="4,0,0,0"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPrivate}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Subtitle}" Opacity="0.6" FontSize="11"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Border Grid.Column="2" Background="#EF4444" CornerRadius="999"
                                                    MinWidth="20" Height="20" Padding="6,0"
                                                    VerticalAlignment="Center" Margin="6,0,2,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasUnread}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding UnreadCount}" Foreground="White"
                                                           FontSize="11" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel Grid.Row="1" Margin="6,6,6,2">
                                <ui:Button Content="Nueva sala"
                                           Command="{Binding CreateRoomCommand}"
                                           HorizontalAlignment="Stretch"
                                           Appearance="Primary"
                                           Margin="0,0,0,6" />
                                <ui:Button Content="Actualizar"
                                           Command="{Binding RefreshRoomsCommand}"
                                           HorizontalAlignment="Stretch"
                                           Appearance="Secondary" />
                            </StackPanel>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <!-- Chat pane -->
            <Border Grid.Column="1" Margin="12,0,0,0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="6">
                <ContentControl Content="{Binding ActiveConversation}">
                    <ContentControl.Resources>
                        <!-- Shared message bubble template -->
                        <DataTemplate x:Key="MessageBubbleTemplate" DataType="{x:Type vm:MessageViewModel}">
                            <Grid Margin="0,2">
                                <Border CornerRadius="8" Padding="8,5" MaxWidth="520">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="HorizontalAlignment" Value="Left" />
                                            <Setter Property="Background" Value="#2A2A2A" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFromMe}" Value="True">
                                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                                    <Setter Property="Background" Value="#1F6FEB" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Body}" TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasBody}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Attachment chip with View + Download buttons -->
                                        <Border Background="#33000000" CornerRadius="6" Padding="8,4" Margin="0,4,0,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasAttachment}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="📎" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding AttachmentLabel}"
                                                           VerticalAlignment="Center" Margin="0,0,10,0"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Button Grid.Column="2"
                                                        Content="👁 Ver"
                                                        Background="Transparent" BorderThickness="0"
                                                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                        Padding="6,2" Margin="0,0,4,0" Cursor="Hand"
                                                        Command="{Binding DataContext.ViewAttachmentCommand, RelativeSource={RelativeSource AncestorType=ContentControl}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Grid.Column="3"
                                                        Content="⬇ Guardar"
                                                        Background="Transparent" BorderThickness="0"
                                                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                        Padding="6,2" Cursor="Hand"
                                                        Command="{Binding DataContext.DownloadAttachmentCommand, RelativeSource={RelativeSource AncestorType=ContentControl}}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </Border>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding SentAtDisplay}"
                                                       FontSize="10" Opacity="0.6" />
                                            <!-- Read ticks: only on outgoing messages -->
                                            <TextBlock FontSize="11" Margin="6,0,0,0" Opacity="0.8">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Setter Property="Text" Value="✓" />
                                                        <Setter Property="Foreground" Value="#AAAAAA" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFromMe}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                                <Setter Property="Text" Value="✓✓" />
                                                                <Setter Property="Foreground" Value="#A0FFFFFF" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>

                        <DataTemplate DataType="{x:Type vm:ChatConversationViewModel}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="8,4">
                                    <TextBlock Text="{Binding Peer.FullName}" FontWeight="Bold" FontSize="14" />
                                    <TextBlock Text="{Binding Peer.DisplayName}" Opacity="0.6" FontSize="11" />
                                </StackPanel>
                                <ScrollViewer Grid.Row="1" Margin="6" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Messages}"
                                                  ItemTemplate="{StaticResource MessageBubbleTemplate}" />
                                </ScrollViewer>
                                <TextBlock Grid.Row="2" Margin="14,0,0,4" FontSize="11" Opacity="0.7"
                                           FontStyle="Italic"
                                           Text="{Binding TypingIndicator}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPeerTyping}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Grid Grid.Row="3" Margin="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:Button Grid.Column="0" Content="📎"
                                               ToolTip="Adjuntar archivo"
                                               Appearance="Secondary"
                                               Padding="8,4"
                                               Margin="0,0,6,0"
                                               Command="{Binding AttachFileCommand}" />
                                    <ui:TextBox Grid.Column="1"
                                                Text="{Binding Draft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                PlaceholderText="Escribe un mensaje…"
                                                AcceptsReturn="False">
                                        <ui:TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding SendCommand}" />
                                        </ui:TextBox.InputBindings>
                                    </ui:TextBox>
                                    <ui:Button Grid.Column="2" Margin="6,0,0,0"
                                               Content="Enviar"
                                               Appearance="Primary"
                                               Command="{Binding SendCommand}" />
                                </Grid>
                            </Grid>
                        </DataTemplate>

                        <DataTemplate DataType="{x:Type vm:RoomConversationViewModel}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="#" FontWeight="Bold" FontSize="14" Opacity="0.6" />
                                            <TextBlock Text="{Binding Room.Name}" FontWeight="Bold" FontSize="14" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Room.Subtitle}" Opacity="0.6" FontSize="11" />
                                    </StackPanel>
                                    <ui:Button Grid.Column="1" Content="Salir de la sala"
                                               Appearance="Caution"
                                               Padding="8,4"
                                               Command="{Binding DataContext.LeaveRoomCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                               CommandParameter="{Binding Room}" />
                                </Grid>
                                <ScrollViewer Grid.Row="1" Margin="6" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Messages}"
                                                  ItemTemplate="{StaticResource MessageBubbleTemplate}" />
                                </ScrollViewer>
                                <TextBlock Grid.Row="2" Margin="14,0,0,4" FontSize="11" Opacity="0.7"
                                           FontStyle="Italic"
                                           Text="{Binding TypingIndicator}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSomeoneTyping}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Grid Grid.Row="3" Margin="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:Button Grid.Column="0" Content="📎"
                                               ToolTip="Adjuntar archivo"
                                               Appearance="Secondary"
                                               Padding="8,4"
                                               Margin="0,0,6,0"
                                               Command="{Binding AttachFileCommand}" />
                                    <ui:TextBox Grid.Column="1"
                                                Text="{Binding Draft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                PlaceholderText="Escribe un mensaje en la sala…"
                                                AcceptsReturn="False">
                                        <ui:TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding SendCommand}" />
                                        </ui:TextBox.InputBindings>
                                    </ui:TextBox>
                                    <ui:Button Grid.Column="2" Margin="6,0,0,0"
                                               Content="Enviar"
                                               Appearance="Primary"
                                               Command="{Binding SendCommand}" />
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </Border>
        </Grid>

        <!-- Loading overlay covers content area until first connection + contacts list load -->
        <Border Grid.Row="3" Background="#A0000000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Conectando con el servidor…" FontSize="16" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,0,0,12" />
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" />
            </StackPanel>
        </Border>

        <Border Grid.Row="4" Padding="12,4"
                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusBanner}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding StatusBanner}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding StatusBanner}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
        </Border>
    </Grid>
</ui:FluentWindow>
