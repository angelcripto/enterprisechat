{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore.SignalR": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/server-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5080"
      }
    }
  },
  "ConnectionStrings": {
    "Sqlite": "Data Source=data/chat.db;Cache=Shared;Foreign Keys=true"
  },
  "EnterpriseChat": {
    "Server": {
      "MaxMessageBodyLength": 4096,
      "MaxAttachmentSizeBytes": 10485760
    },
    "Licensing": {
      "ActivationUrl": "https://enterprisechat.es/activate"
    }
  }
}
