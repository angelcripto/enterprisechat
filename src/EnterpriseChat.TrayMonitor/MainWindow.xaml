<ui:FluentWindow x:Class="EnterpriseChat.TrayMonitor.MainWindow"
                 x:Name="MainWindowRoot"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:tray="clr-namespace:Wpf.Ui.Tray.Controls;assembly=Wpf.Ui.Tray"
                 xmlns:vm="clr-namespace:EnterpriseChat.TrayMonitor.ViewModels"
                 mc:Ignorable="d"
                 Title="EnterpriseChat Server"
                 Icon="pack://application:,,,/Assets/enterprisechat.ico"
                 Height="540" Width="780"
                 MinHeight="420" MinWidth="640"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 Closing="MainWindow_OnClosing"
                 StateChanged="MainWindow_OnStateChanged"
                 d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">
    <Window.Resources>
        <Style x:Key="StatusBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="EnterpriseChat Server" />

        <tray:NotifyIcon x:Name="TrayIcon"
                         Icon="pack://application:,,,/Assets/enterprisechat.ico"
                         TooltipText="{Binding TrayTooltip}"
                         LeftClick="TrayShow_OnClick">
            <tray:NotifyIcon.Menu>
                <ContextMenu>
                    <MenuItem Header="Mostrar EnterpriseChat" Click="TrayShow_OnClick" />
                    <Separator />
                    <MenuItem Header="Arrancar servicio"
                              Command="{Binding StartServiceCommand}" />
                    <MenuItem Header="Detener servicio"
                              Command="{Binding StopServiceCommand}" />
                    <MenuItem Header="Reiniciar servicio"
                              Command="{Binding RestartServiceCommand}" />
                    <Separator />
                    <MenuItem Header="Abrir panel admin"
                              Command="{Binding OpenAdminCommand}" />
                    <MenuItem Header="Cambiar contraseña admin"
                              Command="{Binding ChangeAdminPasswordCommand}" />
                    <Separator />
                    <MenuItem Header="Salir" Click="TrayExit_OnClick" />
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>

        <!-- Estado -->
        <Border Grid.Row="1" Padding="16,12" Margin="16,8,16,4"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                CornerRadius="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Servicio:" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <Border Style="{StaticResource StatusBadge}">
                    <Border.Background>
                        <SolidColorBrush Color="{Binding StatusColor, Converter={StaticResource HexToColorConverter}, FallbackValue=Gray}" />
                    </Border.Background>
                    <TextBlock Text="{Binding StatusLabel}" Foreground="White"
                               FontWeight="SemiBold" />
                </Border>

                <TextBlock Text="Licencia:" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="24,0,8,0" />
                <TextBlock Text="{Binding LicenseLabel}" VerticalAlignment="Center" />

                <TextBlock Text="Usuarios max.:" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="24,0,8,0" />
                <TextBlock Text="{Binding MaxUsersLabel}" VerticalAlignment="Center" />

                <TextBlock Text="🟢"
                           VerticalAlignment="Center" Margin="24,0,4,0"
                           Visibility="{Binding IsHealthy, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock Text="HTTP OK"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsHealthy, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </Border>

        <!-- Acciones -->
        <Border Grid.Row="2" Padding="16,12" Margin="16,4,16,4"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                CornerRadius="10">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <ui:Button Appearance="Primary" Margin="0,0,8,0"
                               Content="Arrancar"
                               Command="{Binding StartServiceCommand}" />
                    <ui:Button Margin="0,0,8,0"
                               Content="Detener"
                               Command="{Binding StopServiceCommand}" />
                    <ui:Button Margin="0,0,8,0"
                               Content="Reiniciar"
                               Command="{Binding RestartServiceCommand}" />
                    <ui:Button Margin="0,0,8,0"
                               Content="Abrir panel admin"
                               Command="{Binding OpenAdminCommand}" />
                    <ui:Button Margin="0,0,8,0"
                               Content="Cambiar contraseña admin"
                               Command="{Binding ChangeAdminPasswordCommand}" />
                    <ui:Button Margin="0,0,8,0"
                               Content="Refrescar"
                               Command="{Binding RefreshNowCommand}" />
                </StackPanel>

                <Border Margin="0,8,0,0" Padding="10,8"
                        Background="#fff3cd" BorderBrush="#f0c000"
                        BorderThickness="1" CornerRadius="6"
                        Visibility="{Binding IsAdmin, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️  TrayMonitor no se ha lanzado como administrador. Los botones de servicio están deshabilitados."
                                   VerticalAlignment="Center" Margin="0,0,12,0" />
                        <ui:Button Content="Relanzar como administrador"
                                   Command="{Binding RelaunchAsAdminCommand}" />
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding BusyMessage}" Margin="0,8,0,0"
                           Foreground="#6a737d" FontStyle="Italic"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </Border>

        <!-- Logs -->
        <Border Grid.Row="3" Padding="16,12" Margin="16,4,16,8"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Últimas líneas del log del servidor" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding LastLog}"
                               FontFamily="Consolas"
                               FontSize="12"
                               TextWrapping="NoWrap" />
                </ScrollViewer>
            </Grid>
        </Border>

        <TextBlock Grid.Row="4" Margin="16,0,16,8"
                   Text="EnterpriseChat Server · TrayMonitor"
                   Foreground="#6a737d" FontSize="11" />
    </Grid>
</ui:FluentWindow>
