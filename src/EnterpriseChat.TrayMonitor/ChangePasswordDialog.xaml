<ui:FluentWindow x:Class="EnterpriseChat.TrayMonitor.ChangePasswordDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Cambiar contraseña del administrador"
                 Icon="pack://application:,,,/Assets/enterprisechat.ico"
                 Height="320" Width="460"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Cambiar contraseña del administrador" />

        <StackPanel Grid.Row="1" Margin="20,12,20,20">
            <TextBlock Text="Introduce la nueva contraseña para el usuario admin. Mínimo 4 caracteres."
                       TextWrapping="Wrap" Margin="0,0,0,12"
                       Foreground="#475569" />

            <TextBlock Text="Nueva contraseña" Margin="0,8,0,4" FontWeight="SemiBold" />
            <PasswordBox x:Name="NewPasswordBox" Height="32"
                         PasswordChanged="OnPasswordChanged" />

            <TextBlock Text="Confirmar contraseña" Margin="0,12,0,4" FontWeight="SemiBold" />
            <PasswordBox x:Name="ConfirmPasswordBox" Height="32"
                         PasswordChanged="OnPasswordChanged" />

            <TextBlock x:Name="ErrorLabel" Margin="0,8,0,0"
                       Foreground="#cb2431" FontSize="12"
                       Visibility="Collapsed" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <ui:Button x:Name="CancelButton" Content="Cancelar"
                           Margin="0,0,8,0" Click="OnCancelClick" />
                <ui:Button x:Name="SaveButton" Content="Guardar"
                           Appearance="Primary" IsEnabled="False"
                           Click="OnSaveClick" />
            </StackPanel>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
